{
  "name": "byok-vid-creator",
  "version": "0.1.0",
  "private": true,
  "description": "BYOK-Vid-Creator — deterministic video production studio",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron .",
    "build": "tsc && vite build",
    "start": "concurrently \"npm:dev\" \"wait-on tcp:5173 && npm:dev:electron\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5",
    "framer-motion": "^11.3.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "tailwindcss": "^3.4.10",
    "postcss": "^8.4.41",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
